<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0E27"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:id="@+id/tv_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="官方中央银行\n模拟投资办理终端"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#FFD700"
            android:gravity="center"
            android:letterSpacing="0.05"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="32dp"
            android:fontFamily="sans-serif-medium" />

        <!-- NFC Card Area -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_nfc_area"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="#1A1F3A"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="32dp"
                android:gravity="center">

                <ImageView
                    android:id="@+id/iv_nfc_icon"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/ic_nfc"
                    android:tint="#FFD700"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:id="@+id/tv_nfc_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="请将NFC卡贴近设备"
                    android:textSize="18sp"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_card_uid"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="等待读卡..."
                    android:textSize="14sp"
                    android:textColor="#B0B0B0"
                    android:fontFamily="monospace" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Participant Info Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_participant_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:visibility="gone"
            app:cardBackgroundColor="#1A1F3A"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="账户信息"
                    android:textSize="16sp"
                    android:textColor="#FFD700"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tv_participant_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="姓名 (班级)"
                    android:textSize="18sp"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="8dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#2A2F4A"
                    android:layout_marginVertical="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="活动账户"
                            android:textSize="12sp"
                            android:textColor="#B0B0B0"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tv_account_balance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="¥0.00"
                            android:textSize="20sp"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="投资币账户"
                            android:textSize="12sp"
                            android:textColor="#B0B0B0"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tv_stock_balance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="¥0.00"
                            android:textSize="20sp"
                            android:textColor="#FFD700"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Investment Form Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_investment_form"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:visibility="gone"
            app:cardBackgroundColor="#1A1F3A"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="投资信息"
                    android:textSize="16sp"
                    android:textColor="#FFD700"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <!-- Booth Selection -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="选择投资摊位"
                    android:textSize="14sp"
                    android:textColor="#B0B0B0"
                    android:layout_marginBottom="8dp" />

                <Spinner
                    android:id="@+id/spinner_booth"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_rounded_card"
                    android:padding="12dp"
                    android:layout_marginBottom="16dp" />

                <!-- Shares Input -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="购买股数"
                    android:textSize="14sp"
                    android:textColor="#B0B0B0"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/et_shares"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_rounded_card"
                    android:padding="16dp"
                    android:hint="请输入购买股数"
                    android:textColorHint="#606060"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:inputType="number"
                    android:layout_marginBottom="16dp" />

                <!-- Total Amount -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#2A2F4A"
                    android:layout_marginVertical="8dp" />

                <TextView
                    android:id="@+id/tv_total_amount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="总金额: ¥0.00"
                    android:textSize="20sp"
                    android:textColor="#FFD700"
                    android:textStyle="bold"
                    android:layout_gravity="end" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Confirm Button -->
        <Button
            android:id="@+id/btn_confirm_investment"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="确认投资"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#0A0E27"
            android:background="@drawable/bg_button_primary"
            android:elevation="8dp"
            android:layout_marginBottom="16dp" />

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"
            android:indeterminateTint="#FFD700" />

    </LinearLayout>

</ScrollView>
