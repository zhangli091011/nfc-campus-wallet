<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- NFC Permission -->
    <uses-permission android:name="android.permission.NFC" />
    <uses-feature
        android:name="android.hardware.nfc"
        android:required="true" />

    <!-- Network and Storage for OTA Update -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" 
        android:maxSdkVersion="28" />
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <!-- Internet Permission for API calls -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Vibration Permission for feedback -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.NFCCampusWallet"
        android:usesCleartextTraffic="true"
        tools:targetApi="31">
        
        <!-- Login Activity (Launcher) -->
        <activity
            android:name=".ui.LoginActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
        <!-- Booth Selection Activity -->
        <activity
            android:name=".ui.BoothSelectionActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        
        <!-- Cashier Activity -->
        <activity
            android:name=".ui.CashierActivity"
            android:exported="false"
            android:screenOrientation="portrait">
            <!-- NFC Intent Filter -->
            <intent-filter>
                <action android:name="android.nfc.action.TECH_DISCOVERED" />
            </intent-filter>
            
            <meta-data
                android:name="android.nfc.action.TECH_DISCOVERED"
                android:resource="@xml/nfc_tech_filter" />
        </activity>
        
        <!-- Main Activity (Legacy) -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        
        <!-- Transaction History Activity -->
        <activity
            android:name=".ui.TransactionHistoryActivity"
            android:exported="false"
            android:parentActivityName=".ui.CashierActivity"
            android:screenOrientation="portrait" />

        <!-- Investment Activity (Compose - 官方中央银行) -->
        <activity
            android:name=".ui.investment.InvestmentComposeActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.NFCCampusWallet.Investment">
            <intent-filter>
                <action android:name="android.nfc.action.TECH_DISCOVERED" />
            </intent-filter>

            <meta-data
                android:name="android.nfc.action.TECH_DISCOVERED"
                android:resource="@xml/nfc_tech_filter" />
        </activity>

        <!-- Bank Teller Activity (Compose - 信用垫资发行终端) -->
        <activity
            android:name=".ui.bankTeller.BankTellerActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.NFCCampusWallet.Investment">
            <intent-filter>
                <action android:name="android.nfc.action.TECH_DISCOVERED" />
            </intent-filter>

            <meta-data
                android:name="android.nfc.action.TECH_DISCOVERED"
                android:resource="@xml/nfc_tech_filter" />
        </activity>

        <!-- Refund Manager Activity (Compose - 收银端退款管理) -->
        <activity
            android:name=".ui.refund.RefundManagerActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.NFCCampusWallet.Investment">
            <intent-filter>
                <action android:name="android.nfc.action.TECH_DISCOVERED" />
            </intent-filter>

            <meta-data
                android:name="android.nfc.action.TECH_DISCOVERED"
                android:resource="@xml/nfc_tech_filter" />
        </activity>

        <!-- Card Detail Activity (Compose - 刷卡查看用户明细) -->
        <activity
            android:name=".ui.cardDetail.CardDetailActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.NFCCampusWallet.Investment">
            <intent-filter>
                <action android:name="android.nfc.action.TECH_DISCOVERED" />
            </intent-filter>

            <meta-data
                android:name="android.nfc.action.TECH_DISCOVERED"
                android:resource="@xml/nfc_tech_filter" />
        </activity>

        <!-- Card Return Activity (Compose - 还款+退卡终端) -->
        <activity
            android:name=".ui.cardReturn.CardReturnActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.NFCCampusWallet.Investment">
            <intent-filter>
                <action android:name="android.nfc.action.TECH_DISCOVERED" />
            </intent-filter>

            <meta-data
                android:name="android.nfc.action.TECH_DISCOVERED"
                android:resource="@xml/nfc_tech_filter" />
        </activity>

        <!-- Refund Approval Activity (Compose - 退款申请审批) -->
        <activity
            android:name=".ui.refundApproval.RefundApprovalActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.NFCCampusWallet.Investment" />
        <!-- FileProvider for APK installation -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>
