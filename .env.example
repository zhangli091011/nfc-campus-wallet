# NFC Campus E-Wallet System - Environment Configuration
# Copy this file to .env and fill in your actual values

# Security Configuration (REQUIRED)
SECRET_KEY=your_secret_key_here_change_this_in_production

# Database Configuration (REQUIRED)
DATABASE_USER=your_database_user
DATABASE_PASSWORD=your_database_password

# Database Configuration (Optional - defaults provided)
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_NAME=nfc_wallet

# Database Connection Pool Configuration (Optional)
# Pool size: Number of connections to maintain in the pool
DATABASE_POOL_SIZE=10
# Max overflow: Additional connections beyond pool_size
DATABASE_MAX_OVERFLOW=20
# Pool timeout: Seconds to wait for a connection from the pool
DATABASE_POOL_TIMEOUT=30
# Pool recycle: Recycle connections after this many seconds (prevents stale connections)
DATABASE_POOL_RECYCLE=3600

# Timestamp Validation Configuration (Optional)
TIMESTAMP_WINDOW=60

# Transaction Configuration (Optional)
MAX_TRANSACTION_AMOUNT=10000.00

# Server Configuration (Optional)
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
